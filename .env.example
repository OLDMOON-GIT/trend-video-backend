# OpenAI API (선택 - 프리미엄 품질)
OPENAI_API_KEY=your_openai_api_key_here

# Groq API (무료 대안 - 빠른 LLM)
GROQ_API_KEY=your_groq_api_key_here

# Replicate API (저렴한 이미지 생성)
REPLICATE_API_TOKEN=your_replicate_token_here

# Hugging Face API (무료 이미지 생성)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Database Configuration
DATABASE_URL=sqlite:///./trend_video.db
# For PostgreSQL: postgresql://user:password@localhost/dbname

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Storage Configuration
STORAGE_PATH=./storage
OUTPUT_PATH=./output
TEMP_PATH=./temp

# Redis (for Celery background tasks)
REDIS_URL=redis://localhost:6379/0

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# JWT Secret (for authentication, if needed)
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# LLM Provider (openai, groq, ollama)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Image Generation Provider (openai, replicate, huggingface, google)
IMAGE_PROVIDER=replicate

# TTS Voice (Edge-TTS voice ID)
TTS_VOICE=ko-KR-SunHiNeural

# Whisper Model (tiny, base, small, medium, large)
WHISPER_MODEL=base

# Google Custom Search (Optional - 하루 100회 무료)
GOOGLE_API_KEY=your_google_api_key
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id
